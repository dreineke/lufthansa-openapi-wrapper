{
  "name": "lufthansa-openapi-wrapper",
  "version": "1.0.1",
  "description": "Lufthansa OpenAPI Wrapper",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepublishOnly": "npm run build",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dreineke/lufthansa-openapi-wrapper.git"
  },
  "keywords": [
    "lufthansa-openapi",
    "lufthansa",
    "lh-openapi"
  ],
  "author": "Dustin Reineke",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/dreineke/lufthansa-openapi-wrapper/issues"
  },
  "homepage": "https://github.com/dreineke/lufthansa-openapi-wrapper#readme",
  "devDependencies": {
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
